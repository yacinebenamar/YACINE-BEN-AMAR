rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Catch-all default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && (isOwner(userId) || exists(/databases/$(database)/documents/users/$(request.auth.uid)));
      allow delete: if false;
    }

    // 2. Categories Collection
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 3. Tasks Collection
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 4. Expenses Collection
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 5. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 6. Stock Transfers Collection
    match /transfers/{transferId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 7. Client Orders Collection
    match /clientOrders/{orderId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 8. Client Debts Collection
    match /clientDebts/{debtId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 9. Camion Routes Collection
    match /camionRoutes/{routeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 10. Supplier Alerts Collection
    match /supplierAlerts/{alertId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
