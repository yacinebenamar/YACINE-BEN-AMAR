{
  "entities": {
    "User": {
      "title": "User",
      "description": "AppUser system registration and login properties",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "worker"] },
        "fullName": { "type": "string" },
        "isActive": { "type": "boolean" },
        "password": { "type": "string" }
      },
      "required": ["uid", "email", "role", "fullName", "isActive"]
    },
    "Category": {
      "title": "Category",
      "description": "Company operational categories for tasks or expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["expense", "task"] }
      },
      "required": ["id", "name", "type"]
    },
    "Task": {
      "title": "Task",
      "description": "Field operation tasks assigned to workers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "assignedToName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "done"] },
        "createdAt": { "type": "string" },
        "archived": { "type": "boolean" },
        "archivedAt": { "type": "string" }
      },
      "required": ["id", "title", "assignedTo", "status", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Field and office financial expenses and invoices",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "submittedBy": { "type": "string" },
        "submittedByName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "amount", "category", "submittedBy", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app system broadcast notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "targetType": { "type": "string", "enum": ["all", "specific"] },
        "targetUid": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "body", "targetType", "isRead", "createdAt"]
    },
    "StockTransfer": {
      "title": "StockTransfer",
      "description": "Stock movements from warehouse to store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemName": { "type": "string" },
        "partName": { "type": "string" },
        "quantity": { "type": "number" },
        "fromLocation": { "type": "string" },
        "toLocation": { "type": "string" },
        "movedByUid": { "type": "string" },
        "movedByName": { "type": "string" },
        "isEnteredInSalesSystem": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "entered"] }
      },
      "required": ["id", "partName", "quantity", "fromLocation", "toLocation", "isEnteredInSalesSystem", "status", "createdAt"]
    },
    "ClientOrder": {
      "title": "ClientOrder",
      "description": "Client orders for parts preparation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "delivered", "prepared"] },
        "items": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "clientName", "deliveryDate", "status", "items", "createdAt"]
    },
    "ClientDebt": {
      "title": "ClientDebt",
      "description": "Outstanding client credit and debts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["unpaid", "paid", "overdue", "partial"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "clientName", "totalAmount", "paidAmount", "dueDate", "status", "createdAt"]
    },
    "CamionRoute": {
      "title": "CamionRoute",
      "description": "Camion distribution routes and tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dayOfWeek": { "type": "string" },
        "routePath": { "type": "string" },
        "driverName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "dayOfWeek", "routePath", "driverName"]
    },
    "SupplierAlert": {
      "title": "SupplierAlert",
      "description": "Alerts regarding suppliers defects and debts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierName": { "type": "string" },
        "type": { "type": "string", "enum": ["debt", "merchandise_error", "call_reason"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "supplierName", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users credentials and operational access details"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Allowed categorization types"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Missions assigned to operators"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Worker expenses awaiting review or finalized"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notices and system alerts"
    },
    "/transfers/{transferId}": {
      "schema": "StockTransfer",
      "description": "Stock transfer operations"
    },
    "/clientOrders/{orderId}": {
      "schema": "ClientOrder",
      "description": "Wholesale client orders"
    },
    "/clientDebts/{debtId}": {
      "schema": "ClientDebt",
      "description": "Outstanding customer credits"
    },
    "/camionRoutes/{routeId}": {
      "schema": "CamionRoute",
      "description": "Truck distribution logs"
    },
    "/supplierAlerts/{alertId}": {
      "schema": "SupplierAlert",
      "description": "Supplier operational claims"
    }
  }
}
